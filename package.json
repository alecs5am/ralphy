{
  "name": "ugc-cli",
  "version": "0.1.0",
  "description": "My Remotion video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "bin": {
    "ralphy": "./cli/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@remotion/captions": "4.0.441",
    "@remotion/cli": "4.0.441",
    "@remotion/google-fonts": "4.0.441",
    "@remotion/tailwind-v4": "4.0.441",
    "@remotion/transitions": "4.0.441",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.4.0",
    "playwright": "^1.58.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.441",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.441",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "husky": "^9.1.7",
    "prettier": "3.8.1",
    "tsx": "^4.19.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "build:bin": "tsx scripts/build-binaries.ts",
    "build:bin:current": "tsx scripts/build-binaries.ts --current",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "ralph": "bun cli/index.ts",
    "ralphy": "bun cli/index.ts",
    "setup": "bun cli/index.ts setup",
    "doctor": "bun cli/index.ts doctor",
    "render": "bun cli/index.ts render",
    "test": "bun test tests/",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "test:live": "RUN_LIVE_TESTS=1 bun test tests/live/",
    "lint:errors": "bun run scripts/lint-error-codes.ts",
    "lint:help-examples": "bun run scripts/lint-help-examples.ts",
    "cli:surface:build": "bun run scripts/build-cli-surface.ts",
    "cli:surface:check": "bun run scripts/build-cli-surface.ts --check",
    "docs:cli": "bun run scripts/build-cli-docs.ts",
    "docs:cli:check": "bun run scripts/build-cli-docs.ts --check",
    "lint:docs-links": "bun run scripts/lint-docs-links.ts",
    "lint:docs-links:fast": "bun run scripts/lint-docs-links.ts --no-net",
    "_dashboard:legacy": "cd dashboard && bunx tsx server/index.ts",
    "_dashboard:dev:legacy": "cd dashboard && bunx vite --port 5173",
    "prepare": "husky"
  },
  "sideEffects": [
    "*.css"
  ]
}
