{
  "$schema": "./tokens.schema.json",
  "version": 1,
  "description": "Ralphy canonical brand tokens. Source of truth for palette + fonts across landing, Mintlify, CLI, and README. See 07.06.01 in roadmap/07-socials-and-docs/SPEC.md.",
  "colors": {
    "primary": {
      "value": "#FF7A1A",
      "name": "Ralphy orange",
      "used_in": ["mintlify.primary", "cli.ui.c.brand", "landing.cta", "logo.fill"]
    },
    "primary_light": {
      "value": "#FF9248",
      "name": "Ralphy orange — light",
      "used_in": ["mintlify.colors.light", "landing.hover-states"]
    },
    "primary_dark": {
      "value": "#E0641A",
      "name": "Ralphy orange — dark",
      "used_in": ["mintlify.colors.dark", "landing.active-states"]
    },
    "accent": {
      "value": "#E87BA1",
      "name": "Terminal pink (dusty rose)",
      "used_in": ["cli.ui.c.accent", "landing.--vio", "selection-highlight"]
    },
    "accent_light": {
      "value": "#F2A0BD",
      "name": "Terminal pink — light",
      "used_in": ["landing.--vio-2"]
    },
    "accent_dark": {
      "value": "#C75C82",
      "name": "Terminal pink — dark",
      "used_in": ["landing.--vio-3"]
    },
    "background": {
      "value": "#0A0A0B",
      "name": "Stage black",
      "used_in": ["landing.--bg", "mintlify.background.dark", "mintlify.background.light"]
    },
    "ink": {
      "value": "#F5F5F4",
      "name": "Ink (foreground)",
      "used_in": ["landing.--ink", "mintlify.text"]
    },
    "muted": {
      "value": "#8E8E8B",
      "name": "Muted ink",
      "used_in": ["landing.--mute", "cli.ui.c.muted"]
    }
  },
  "fonts": {
    "heading": {
      "family": "AWS Diatype Mono",
      "weight": 700,
      "source": "docs-mintlify/fonts/AWSDiatypeRoundedSemi-Mono-Bold.woff2",
      "fallback": "ui-monospace, SFMono-Regular, Menlo, monospace"
    },
    "body": {
      "family": "AWS Diatype",
      "weight": 400,
      "source": "docs-mintlify/fonts/AWSDiatype-Regular.woff2",
      "fallback": "-apple-system, system-ui, sans-serif"
    },
    "code": {
      "family": "Fragment Mono",
      "weight": 400,
      "source": "docs-mintlify/fonts/FragmentMono-Regular.woff2",
      "fallback": "ui-monospace, SFMono-Regular, Menlo, monospace"
    }
  },
  "logo": {
    "primary": "docs/branding/banner.png",
    "favicon_svg": "docs-mintlify/favicon.svg",
    "favicon_png": "docs-mintlify/favicon.png",
    "mark_dark": "docs-mintlify/logo.svg",
    "mark_light": "docs-mintlify/logo.svg"
  },
  "voice": {
    "tagline": "An autonomous UGC-video studio in one repo.",
    "subtagline": "Drive it from a chat. Get an mp4 in ~8 minutes.",
    "name_canonical": "ralphy",
    "name_display": "Ralphy"
  }
}
