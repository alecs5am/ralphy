{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ralphy",
  "description": "The AI film studio that lives in your terminal.",
  "colors": {
    "primary": "#FF7A1A",
    "light": "#FF9248",
    "dark": "#E0641A"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "heading": {
      "family": "AWS Diatype Mono",
      "source": "https://raw.githubusercontent.com/alecs5am/ralphy/main/docs-mintlify/fonts/AWSDiatypeRoundedSemi-Mono-Bold.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "AWS Diatype",
      "source": "https://raw.githubusercontent.com/alecs5am/ralphy/main/docs-mintlify/fonts/AWSDiatype-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#0A0A0B",
      "light": "#0A0A0B"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Star on GitHub",
      "href": "https://github.com/alecs5am/ralphy"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["introduction", "quickstart", "concepts"]
          },
          {
            "group": "CLI",
            "pages": ["cli/overview", "cli/setup", "cli/project", "cli/template", "cli/profile"]
          },
          {
            "group": "Authoring",
            "pages": [
              "authoring/skills",
              "authoring/templates",
              "authoring/templates-index",
              "authoring/playbooks",
              "authoring/profiles",
              {
                "group": "Cookbook",
                "pages": [
                  "authoring/cookbook/image",
                  "authoring/cookbook/video",
                  "authoring/cookbook/voice",
                  "authoring/cookbook/music"
                ]
              }
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/models",
              "reference/troubleshooting",
              {
                "group": "CLI verbs (auto-generated)",
                "pages": [
                  "reference/cli/setup",
                  "reference/cli/doctor",
                  "reference/cli/status",
                  "reference/cli/new",
                  "reference/cli/clone",
                  "reference/cli/render",
                  "reference/cli/generate",
                  "reference/cli/skill",
                  "reference/cli/project",
                  "reference/cli/template",
                  "reference/cli/ref",
                  "reference/cli/brand",
                  "reference/cli/persona",
                  "reference/cli/models",
                  "reference/cli/assets",
                  "reference/cli/queue",
                  "reference/cli/batch",
                  "reference/cli/eval"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/alecs5am/ralphy",
      "x": "https://twitter.com/ralphy_studio",
      "discord": "https://discord.gg/ralphy"
    }
  },
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo.svg"
  }
}
